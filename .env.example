# Pricing (Philippine Peso)
BLACK_AND_WHITE_PRICE=3.0
COLOR_PRICE=5.0

# Printer
PRINTER_NAME=Your_CUPS_Printer_Name   # run `lpstat -p` to find the name

# Additional printer settings
PRINTER_TIMEOUT=30
PRINTER_RETRY_ATTEMPTS=3

# System settings
DEFAULT_COLOR_MODE=Black and White
MAX_COPIES=99
MIN_COPIES=1

# Analysis settings for color reading
PDF_ANALYSIS_DPI=150
COLOR_TOLERANCE=15
PIXEL_COUNT_THRESHOLD=200

# SMS alerts — phone number to receive error/status notifications
PHONE_NUMBER=09XXXXXXXXX

# Hardware GPIO pins
COIN_PIN=12       # Coin acceptor pulse input
BILL_PIN=18       # Bill acceptor pulse input
COIN_INHIBIT_PIN=22  # Coin acceptor enable (active high: HIGH=enabled, LOW=disabled)
BILL_INHIBIT_PIN=23  # Bill acceptor enable (active low: LOW=enabled, HIGH=disabled)

# Set to true to skip GPIO, CUPS, and modem hardware (for laptop development)
SIM_MODE=true

# FastAPI backend (SSP/webapp) — must be false in production deployments
API_DOCS_ENABLED=true

# Wi-Fi upload portal (webapp/routers/upload.py) — both optional, defaults shown
WIFI_UPLOAD_DIR=SSP/database/wifi_uploads
MAX_UPLOAD_SIZE_MB=25

# Email intake (managers/adapters/email_adapter.py) — all optional, defaults
# shown below point at the greenmail dev server (managers/adapters/greenmail/
# docker-compose.yml). Override every one of these before pointing at the
# real dedicated Gmail account — e.g. EMAIL_USE_SSL=true, EMAIL_IMAP_PORT=993,
# EMAIL_SMTP_PORT=465, an app password. No code changes needed for that swap.
EMAIL_IMAP_HOST=127.0.0.1
EMAIL_IMAP_PORT=3143
EMAIL_SMTP_HOST=127.0.0.1
EMAIL_SMTP_PORT=3025
EMAIL_USE_SSL=false
EMAIL_USER=test@example.com
EMAIL_PASSWORD=test
EMAIL_MAILBOX=INBOX
EMAIL_SUBJECT_KEYWORD=DEMO_TRIGGER
EMAIL_POLL_INTERVAL_SECONDS=10
EMAIL_UPLOAD_DIR=SSP/database/email_uploads
EMAIL_MAX_ATTACHMENT_SIZE_MB=25
